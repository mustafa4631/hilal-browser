{
  "name": "hilal-browser",
  "private": true,
  "description": "Hilal Browser overlay. See docs/ for build instructions.",
  "scripts": {
    "check:repo-guardrails": "node scripts/check-release-metadata.mjs",
    "check:release-metadata": "node scripts/check-release-metadata.mjs",
    "locales:setup": "bash scripts/setup-locales.sh",
    "locales:merge": "python3 scripts/merge-locales.py . engine",
    "locales:check": "python3 scripts/check-locales.py",
    "locales:build": "bash scripts/build-langpacks.sh",
    "release:env": "node scripts/release-env.mjs",
    "release:check-assets": "node scripts/check-release-assets.mjs",
    "smoke:browser": "bash scripts/smoke-browser.sh",
    "setup:deps": "powershell -ExecutionPolicy Bypass -File scripts/install-deps-windows.ps1",
    "build": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1",
    "build:faster": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1 -Faster",
    "build:binaries": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1 -Binaries",
    "run": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1 -Run",
    "package": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1 -Package"
  }
}
