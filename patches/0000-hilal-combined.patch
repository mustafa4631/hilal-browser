+.hilal-row-active {
+  background: var(--hilal-sidebar-highlight);
+  border-color: color-mix(in srgb, var(--hilal-sidebar-text) 10%, transparent);
+}
+
+.hilal-tab-favicon,
+.hilal-tab-loading {
+  block-size: 16px;
+  border-radius: 3px;
+  flex: 0 0 16px;
+  inline-size: 16px;
+}
+
+.hilal-tab-loading {
+  align-self: center;
+  background: var(--hilal-sidebar-blue);
+  border-radius: 50%;
+  box-shadow: 0 0 0 4px color-mix(in srgb, var(--hilal-sidebar-blue) 16%, transparent);
+  transform: scale(0.55);
+}
+
+.hilal-row-title {
+  flex: 1 1 auto;
+  min-inline-size: 0;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.hilal-tab-close {
+  block-size: 20px;
+  color: var(--hilal-sidebar-muted);
+  flex: 0 0 20px;
+  inline-size: 20px;
+  opacity: 0;
+  pointer-events: none;
+}
+
+.hilal-tab-row:hover .hilal-tab-close,
+.hilal-tab-row:focus-within .hilal-tab-close {
+  opacity: 1;
+  pointer-events: auto;
+}
+
+.hilal-bookmark-row {
+  color: var(--hilal-sidebar-muted);
+  min-block-size: 26px;
+  font-size: 12px;
+}
+
+.hilal-bookmark-badge {
+  background: color-mix(in srgb, var(--hilal-sidebar-blue) 12%, transparent);
+  border: 1px solid color-mix(in srgb, var(--hilal-sidebar-blue) 22%, transparent);
+  border-radius: 4px;
+  color: var(--hilal-sidebar-blue);
+  flex: 0 0 auto;
+  font-size: 10px;
+  font-weight: 700;
+  line-height: 1;
+  max-inline-size: 84px;
+  overflow: hidden;
+  padding: 3px 5px;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.hilal-sidebar-footer {
+  border-block-start: 1px solid var(--hilal-sidebar-border);
+  display: flex;
+  flex: 0 0 auto;
+  flex-direction: column;
+  gap: 8px;
+  padding-block: 12px 16px;
+}
+
+.hilal-footer-group {
+  border-block-end: 1px solid var(--hilal-sidebar-border);
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+  padding-block-end: 8px;
+}
+
+.hilal-footer-group:last-child {
+  border-block-end: 0;
+  padding-block-end: 0;
+}
+
+.hilal-footer-row {
+  appearance: none;
+  align-items: center;
+  background: transparent;
+  border: 0;
+  border-radius: 8px;
+  color: var(--hilal-sidebar-muted);
+  cursor: pointer;
+  display: flex;
+  font: inherit;
+  font-size: 12px;
+  font-weight: 650;
+  gap: 10px;
+  min-block-size: 28px;
+  padding: 0 8px;
+  text-align: start;
+}
