+    updateHilalUiFixSubOptionsState();
+
+    const { HilalBangs } = ChromeUtils.importESModule(
+      "resource:///modules/HilalBangs.sys.mjs"
+    );
+
+    const bangsList = document.getElementById("hilalBangsList");
+    const bangsAddBtn = document.getElementById("hilalBangsAdd");
+    const bangsRemoveBtn = document.getElementById("hilalBangsRemove");
+    const bangsForm = document.getElementById("hilalBangsForm");
+    const bangsTriggerInput = document.getElementById("hilalBangsTrigger");
+    const bangsSearchUrlInput = document.getElementById("hilalBangsSearchUrl");
+    const bangsHomeUrlInput = document.getElementById("hilalBangsHomeUrl");
+    const bangsSaveBtn = document.getElementById("hilalBangsSave");
+    const bangsCancelBtn = document.getElementById("hilalBangsCancel");
+
+    const refreshBangsList = () => {
+      if (!bangsList) {
+        return;
+      }
+      bangsList.textContent = "";
+
+      const defaults = HilalBangs.getDefaultBangs();
+      const customs = HilalBangs.getCustomBangs() || [];
+
+      const addRow = (trigger, search, home, isCustom) => {
+        const item = document.createXULElement("richlistitem");
+        item.setAttribute("style", "padding: 6px; border-bottom: 1px solid var(--in-content-border-color); align-items: center; display: flex; flex-direction: row;");
+        item.setAttribute("trigger", trigger);
+        item.setAttribute("isCustom", isCustom ? "true" : "false");
+
+        const triggerLabel = document.createXULElement("label");
+        triggerLabel.setAttribute("value", "!" + trigger);
+        triggerLabel.setAttribute("style", "font-weight: bold; width: 80px; min-width: 80px; margin-right: 10px;");
+        item.appendChild(triggerLabel);
+
+        const typeLabel = document.createXULElement("label");
+        typeLabel.setAttribute("value", isCustom ? "(custom)" : "(default)");
+        typeLabel.setAttribute("style", "color: gray; width: 80px; min-width: 80px; margin-right: 10px;");
+        item.appendChild(typeLabel);
+
+        const urlLabel = document.createXULElement("label");
+        urlLabel.setAttribute("value", search);
+        urlLabel.setAttribute("flex", "1");
+        urlLabel.setAttribute("crop", "end");
+        item.appendChild(urlLabel);
+
+        bangsList.appendChild(item);
+      };
+
+      for (const entry of customs) {
+        if (entry && entry.trigger) {
+          addRow(entry.trigger, entry.search, entry.home || "", true);
+        }
+      }
+
+      for (const [trigger, data] of Object.entries(defaults)) {
+        addRow(trigger, data.search, data.home, false);
+      }
+    };
+
+    if (bangsList) {
+      bangsList.addEventListener("select", () => {
+        const selected = bangsList.selectedItem;
+        if (selected) {
+          const isCustom = selected.getAttribute("isCustom") === "true";
+          if (bangsRemoveBtn) {
+            bangsRemoveBtn.disabled = !isCustom;
+          }
+        } else {
+          if (bangsRemoveBtn) {
+            bangsRemoveBtn.disabled = true;
+          }
+        }
+      });
+    }
+
+    if (bangsAddBtn) {
+      bangsAddBtn.addEventListener("command", () => {
+        if (bangsForm) {
+          bangsForm.hidden = false;
+        }
+        if (bangsTriggerInput) {
+          bangsTriggerInput.value = "";
+          bangsTriggerInput.focus();
+        }
+        if (bangsSearchUrlInput) {
+          bangsSearchUrlInput.value = "";
+        }
+        if (bangsHomeUrlInput) {
+          bangsHomeUrlInput.value = "";
+        }
+      });
+    }
+
+    if (bangsCancelBtn) {
+      bangsCancelBtn.addEventListener("command", () => {
+        if (bangsForm) {
+          bangsForm.hidden = true;
+        }
+      });
+    }
+
+    if (bangsSaveBtn) {
+      bangsSaveBtn.addEventListener("command", () => {
+        const trigger = bangsTriggerInput ? bangsTriggerInput.value.trim().toLowerCase().replace(/^!/, "") : "";
+        const search = bangsSearchUrlInput ? bangsSearchUrlInput.value.trim() : "";
+        const home = bangsHomeUrlInput ? bangsHomeUrlInput.value.trim() : "";
+
+        if (!trigger || !search) {
+          Services.prompt.alert(window, "Invalid Input", "Trigger and Search URL are required.");
+          return;
+        }
+
+        const defaults = HilalBangs.getDefaultBangs();
+        if (trigger in defaults) {
+          Services.prompt.alert(window, "Duplicate Trigger", "The trigger '!" + trigger + "' is reserved as a default bang.");
+          return;
+        }
+
+        const customs = HilalBangs.getCustomBangs() || [];
+        const existingIndex = customs.findIndex(c => c.trigger === trigger);
+
+        if (existingIndex >= 0) {
+          customs[existingIndex] = { trigger, search, home };
+        } else {
+          customs.push({ trigger, search, home });
+        }
+
+        HilalBangs.setCustomBangs(customs);
+        refreshBangsList();
+
+        if (bangsForm) {
+          bangsForm.hidden = true;
+        }
+      });
+    }
+
+    if (bangsRemoveBtn) {
+      bangsRemoveBtn.addEventListener("command", () => {
+        const selected = bangsList ? bangsList.selectedItem : null;
+        if (!selected) {
+          return;
+        }
+
+        const trigger = selected.getAttribute("trigger");
+        const isCustom = selected.getAttribute("isCustom") === "true";
+
+        if (isCustom && trigger) {
+          if (Services.prompt.confirm(window, "Remove Bang", "Are you sure you want to remove the custom bang '!" + trigger + "'?")) {
+            const customs = HilalBangs.getCustomBangs() || [];
+            const filtered = customs.filter(c => c.trigger !== trigger);
+            HilalBangs.setCustomBangs(filtered);
+            refreshBangsList();
+          }
+        }
+      });
+    }
+
+    refreshBangsList();
+  },
+};
