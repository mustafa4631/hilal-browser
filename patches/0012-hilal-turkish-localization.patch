Hilal Browser: enable Turkish locale by default

Appends the default requested locale preference ("intl.locale.requested" = "tr")
to force the browser to boot in Turkish out of the box when the Turkish
language pack is available.

---

diff --git a/browser/app/profile/firefox.js b/browser/app/profile/firefox.js
--- a/browser/app/profile/firefox.js
+++ b/browser/app/profile/firefox.js
@@ -3695,3 +3695,6 @@
 pref("browser.tabs.hoverPreview.enabled", true);
 pref("browser.urlbar.clipboard.featureGate", true);
 pref("browser.urlbar.suggest.calculator", true);
+
+// Localization Settings
+pref("intl.locale.requested", "tr");
