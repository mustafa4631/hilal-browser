+    function normalizeSidebarShortcutUrl(url) {
+      const value = String(url || "").trim();
+      if (!value) {
+        return "";
+      }
+      if (/^[a-z][a-z0-9+.-]*:/i.test(value)) {
+        return value;
+      }
+      return "https://" + value;
+    }
+
+    function getSidebarShortcutFaviconUrl(url) {
