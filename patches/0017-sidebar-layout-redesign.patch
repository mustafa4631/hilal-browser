+      if (!normalizedUrl) {
+        return "";
+      }
+      try {
+        const uri = Services.io.newURI(normalizedUrl);
+        if (uri.scheme === "http" || uri.scheme === "https") {
+          return "page-icon:" + uri.spec;
+        }
+      } catch (e) {
+        // Keep the user-selected fallback icon for non-URL shortcuts.
+      }
+      return "";
+    }
