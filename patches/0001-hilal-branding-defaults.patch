Hilal Browser: switch default branding directory and app vendor

Repoints the default and official branding directories at the
`browser/branding/hilal/` tree shipped by this repo, sets the
`MOZ_APP_VENDOR` string to `Hilal`, and pins a Hilal-owned
distribution id (`org.hilal`) so the macOS bundle identifier and
helper-process bundle ids reflect the product instead of Firefox.

The branding assets themselves are not part of this patch; they
live under `branding/hilal/` in the hilal-browser repo and are
copied into place by `scripts/apply.sh`.

---
 browser/confvars.sh   | 4 ++--
 browser/moz.configure | 5 ++++-
 2 files changed, 6 insertions(+), 3 deletions(-)

diff --git a/browser/confvars.sh b/browser/confvars.sh
--- a/browser/confvars.sh
+++ b/browser/confvars.sh
@@ -9,5 +9,5 @@
 # For mozilla-beta, mozilla-release, or mozilla-central repositories, use
 # "unofficial" branding.
 # For the mozilla-aurora repository, use "aurora".
-MOZ_BRANDING_DIRECTORY=browser/branding/unofficial
-MOZ_OFFICIAL_BRANDING_DIRECTORY=browser/branding/official
+MOZ_BRANDING_DIRECTORY=browser/branding/hilal
+MOZ_OFFICIAL_BRANDING_DIRECTORY=browser/branding/hilal
diff --git a/browser/moz.configure b/browser/moz.configure
--- a/browser/moz.configure
+++ b/browser/moz.configure
@@ -11,8 +11,11 @@ imply_option("MOZ_NORMANDY", True)
 imply_option("MOZ_PROFILE_MIGRATOR", True)
 
 
-imply_option("MOZ_APP_VENDOR", "Mozilla")
+imply_option("MOZ_APP_VENDOR", "Hilal")
 imply_option("MOZ_APP_ID", "{ec8030f7-c20a-464f-9b0e-13a3a9e97384}")
+# Hilal Browser distribution identifier. Drives macOS CFBundleIdentifier and
+# helper-process bundle ids (e.g. org.hilal.browser.plugincontainer).
+imply_option("--with-distribution-id", "org.hilal")
 # Include the DevTools client, not just the server (which is the default)
 imply_option("MOZ_DEVTOOLS", "all")
 imply_option("BROWSER_CHROME_URL", "chrome://browser/content/browser.xhtml")
