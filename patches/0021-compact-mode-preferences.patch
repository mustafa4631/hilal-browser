diff --git a/browser/themes/shared/sidebar.css b/browser/themes/shared/sidebar.css
index 19fafff8cb45..bdfa20b08d15 100644
--- a/browser/themes/shared/sidebar.css
+++ b/browser/themes/shared/sidebar.css
@@ -682,3 +682,59 @@ sidebar-main,
   border: none !important;
   padding: 0 !important;
 }
+
+/* Hilal Compact Mode — top toolbar auto-hides as a premium floating overlay on hover */
+
+:root[hilal-compact-mode] #navigator-toolbox {
+  position: fixed !important;
+  z-index: 1001 !important;
+  top: 0 !important;
+  left: 12px !important;
+  width: calc(100vw - 24px) !important;
+  margin: 0 !important;
+  border: none !important;
+  padding: 0 !important;
+  
+  /* Slide out of screen and hide by default relative to its own natural height */
+  overflow: visible !important;
+  opacity: 0;
+  visibility: hidden;
+  pointer-events: none;
+  transform: translateY(-100%) !important;
+  
+  will-change: transform, opacity;
+  transition:
+    transform 0.32s cubic-bezier(0.16, 1, 0.3, 1),
+    opacity 0.28s ease-out,
+    visibility 0s 0.32s;
+}
+
+/* Compact Top Toolbar Visible state */
+:root[hilal-compact-mode] #navigator-toolbox.hilal-compact-visible {
+  opacity: 1 !important;
+  visibility: visible !important;
+  pointer-events: auto !important;
+  transform: translateY(0) !important;
+  
+  /* Premium aesthetic: unified floating glassmorphism card */
+  background-color: var(--hilal-sidebar-background, var(--toolbar-background-color, #1e1e2e)) !important;
+  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 2px 12px rgba(0, 0, 0, 0.2) !important;
+  border-radius: 0 0 16px 16px !important;
+  border: 1px solid var(--hilal-sidebar-border, rgba(255, 255, 255, 0.1)) !important;
+  border-top: none !important;
+  
+  transition:
+    transform 0.32s cubic-bezier(0.16, 1, 0.3, 1),
+    opacity 0.28s ease-out,
+    visibility 0s 0s;
+}
+
+/* Expose the unified card background by turning child toolbar backgrounds transparent */
+:root[hilal-compact-mode] #navigator-toolbox.hilal-compact-visible #titlebar,
+:root[hilal-compact-mode] #navigator-toolbox.hilal-compact-visible #nav-bar,
+:root[hilal-compact-mode] #navigator-toolbox.hilal-compact-visible #PersonalToolbar,
+:root[hilal-compact-mode] #navigator-toolbox.hilal-compact-visible #nav-bar-customization-target {
+  background: transparent !important;
+  box-shadow: none !important;
+  border: none !important;
+}
