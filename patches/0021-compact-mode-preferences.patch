+}
+
+#sidebar-main[hilal-sidebar] #pinned-tabs-container[orient="vertical"] .tabbrowser-tab:hover {
+  transform: translateY(-1px) !important;
+}
+
+#sidebar-main[hilal-sidebar] #pinned-tabs-container[orient="vertical"] .tabbrowser-tab[selected="true"] {
+  background-color: var(--hilal-sidebar-highlight) !important;
+  border-color: color-mix(in srgb, var(--hilal-sidebar-text) 10%, transparent) !important;
+}
+
+#sidebar-main[hilal-sidebar] #pinned-tabs-container[orient="vertical"] .tabbrowser-tab .tab-background {
+  border-radius: 8px !important;
+}
+
+/* Unified Split View tab groupings outline */
+#sidebar-main[hilal-sidebar] tab-split-view-wrapper {
+  border: 1px solid var(--hilal-sidebar-border, rgba(255, 255, 255, 0.08)) !important;
+  border-radius: 8px !important;
+  margin-block: 4px !important;
+  padding: 2px !important;
+  background: rgba(0, 0, 0, 0.08) !important;
+}

