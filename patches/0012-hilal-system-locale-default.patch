Hilal Browser: follow system locale by default

Sets the requested locale preference to an empty string so Firefox reads the
operating system locale list. If no installed locale matches, Firefox falls back
to the packaged en-US locale.

---

diff --git a/browser/app/profile/firefox.js b/browser/app/profile/firefox.js
--- a/browser/app/profile/firefox.js
+++ b/browser/app/profile/firefox.js
@@ -3695,3 +3695,9 @@
 pref("browser.tabs.hoverPreview.enabled", true);
 pref("browser.urlbar.clipboard.featureGate", true);
 pref("browser.urlbar.suggest.calculator", true);
+
+// Follow the OS language when a matching locale is installed; otherwise use en-US.
+pref("intl.locale.requested", "");
+
+// Allow custom compiled unsigned language packs
+pref("extensions.langpacks.signatures.required", false);
