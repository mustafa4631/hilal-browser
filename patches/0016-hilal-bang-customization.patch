     "FaviconLoader.sys.mjs",
     "FilterAdult.sys.mjs",
     "FirefoxBridgeExtensionUtils.sys.mjs",
+    "HilalBangs.sys.mjs",
     "HomePage.sys.mjs",
     "LaterRun.sys.mjs",
     "LinksCache.sys.mjs",
