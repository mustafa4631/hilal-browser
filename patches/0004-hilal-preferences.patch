Hilal Browser: add Hilal settings category to preferences

Adds a dedicated "Hilal Browser" category to about:preferences with
workspace controls and a Reset Workspaces button. The pref binding is handled
manually via JS.

---
diff --git a/browser/components/preferences/hilal.inc.xhtml b/browser/components/preferences/hilal.inc.xhtml
new file mode 100644
--- /dev/null
+++ b/browser/components/preferences/hilal.inc.xhtml
@@ -0,0 +1,33 @@
+# This Source Code Form is subject to the terms of the Mozilla Public
+# License, v. 2.0. If a copy of the MPL was not distributed with this
+# file, You can obtain one at http://mozilla.org/MPL/2.0/.
+
+<!-- Hilal Browser panel -->
+
+<html:template id="template-paneHilal">
+<hbox id="hilalCategory"
+      class="subcategory"
+      hidden="true"
+      data-category="paneHilal">
+  <html:h1 data-l10n-id="hilal-settings-header"/>
+</hbox>
+
+<groupbox id="hilalWorkspacesGroup" data-category="paneHilal" hidden="true">
+  <label><html:h2 data-l10n-id="hilal-workspaces-header"/></label>
+  <vbox align="start">
+    <checkbox id="hilalWorkspacesEnabled"
+              label="Enable workspaces"/>
+    <checkbox id="hilalWorkspacesPinnedPublic"
+              label="Make pinned tabs visible in all workspaces"/>
+    <checkbox id="hilalWorkspacesGroupsPublic"
+              label="Make tab groups visible in all workspaces"/>
+    <hbox>
+      <description flex="1">Reset all workspace data (cannot be undone).</description>
+      <button id="hilalWorkspacesReset"
+              is="highlightable-button"
+              class="accessory-button"
+              label="Reset Workspaces"/>
+    </hbox>
+  </vbox>
+</groupbox>
+</html:template>
diff --git a/browser/components/preferences/main.js b/browser/components/preferences/main.js
--- a/browser/components/preferences/main.js
+++ b/browser/components/preferences/main.js
@@ -13,7 +13,7 @@
 /* import-globals-from preferences.js */
 /* import-globals-from /toolkit/mozapps/preferences/fontbuilder.js */
 /* import-globals-from /browser/base/content/aboutDialog-appUpdater.js */
-/* global MozXULElement */
+/* global ContextualIdentityService, MozXULElement, Services */
 
 /**
  * @import { Setting } from "chrome://global/content/preferences/Setting.mjs"
@@ -26,6 +26,8 @@ const { Multilingual } = ChromeUtils.importESModule(
 
 ChromeUtils.defineESModuleGetters(this, {
   BackgroundUpdate: "resource://gre/modules/BackgroundUpdate.sys.mjs",
+  ContextualIdentityService:
+    "resource://gre/modules/ContextualIdentityService.sys.mjs",
   UpdateListener: "resource://gre/modules/UpdateListener.sys.mjs",
   LinkPreview: "moz-src:///browser/components/genai/LinkPreview.sys.mjs",
   MigrationUtils: "resource:///modules/MigrationUtils.sys.mjs",
@@ -1811,6 +1813,114 @@ gMainPane.initialized = new Promise(res => {
   gMainPane.setInitialized = res;
 });
 
+var gHilalPane = {
+  init() {
+    /**
+     * @param {string} aId
+     * @param {string} aEventType
+     * @param {(ev: Event) => void} aCallback
+     */
+    function setEventListener(aId, aEventType, aCallback) {
+      document.getElementById(aId).addEventListener(aEventType, aCallback);
+    }
+
+    const hilalWsCheckbox = /** @type {HTMLInputElement|null} */ (
+      document.getElementById("hilalWorkspacesEnabled")
+    );
+    const hilalWsPinnedPublicCheckbox = /** @type {HTMLInputElement|null} */ (
+      document.getElementById("hilalWorkspacesPinnedPublic")
+    );
+    const hilalWsGroupsPublicCheckbox = /** @type {HTMLInputElement|null} */ (
+      document.getElementById("hilalWorkspacesGroupsPublic")
+    );
+    const resetHilalWorkspaceContainers = () => {
+      let workspaces = [];
+      try {
+        workspaces = JSON.parse(
+          Services.prefs.getStringPref("hilal.workspaces.data", "[]")
+        );
+      } catch (e) {
+        console.warn("Failed to parse Hilal workspace data during reset", e);
+      }
+      if (!Array.isArray(workspaces)) {
+        return;
+      }
+      for (const workspace of workspaces) {
+        const containerId = Number.parseInt(workspace?.containerId, 10);
+        if (containerId) {
+          try {
+            ContextualIdentityService.remove(containerId);
+          } catch (e) {
+            console.warn("Failed to remove Hilal workspace container", e);
+          }
+        }
+      }
+    };
+
+    if (hilalWsCheckbox) {
+      hilalWsCheckbox.checked = Services.prefs.getBoolPref(
+        "hilal.workspaces.enabled",
+        true
+      );
+      hilalWsCheckbox.addEventListener("command", function () {
+        Services.prefs.setBoolPref(
+          "hilal.workspaces.enabled",
+          hilalWsCheckbox.checked
+        );
+      });
+    }
+    if (hilalWsPinnedPublicCheckbox) {
+      hilalWsPinnedPublicCheckbox.checked = Services.prefs.getBoolPref(
+        "hilal.workspaces.pinned.public",
+        false
+      );
+      hilalWsPinnedPublicCheckbox.addEventListener("command", function () {
+        Services.prefs.setBoolPref(
+          "hilal.workspaces.pinned.public",
+          hilalWsPinnedPublicCheckbox.checked
+        );
+      });
+    }
+    if (hilalWsGroupsPublicCheckbox) {
+      hilalWsGroupsPublicCheckbox.checked = Services.prefs.getBoolPref(
+        "hilal.workspaces.groups.public",
+        false
+      );
+      hilalWsGroupsPublicCheckbox.addEventListener("command", function () {
+        Services.prefs.setBoolPref(
+          "hilal.workspaces.groups.public",
+          hilalWsGroupsPublicCheckbox.checked
+        );
+      });
+    }
+    setEventListener("hilalWorkspacesReset", "command", function () {
+      if (
+        Services.prompt.confirm(
+          window,
+          "Reset Workspaces",
+          "This will delete all workspace data and cannot be undone. Continue?"
+        )
+      ) {
+        resetHilalWorkspaceContainers();
+        Services.prefs.setStringPref("hilal.workspaces.data", "[]");
+        Services.prefs.setStringPref("hilal.workspaces.active", "default");
+        Services.prefs.setBoolPref("hilal.workspaces.enabled", true);
+        Services.prefs.setBoolPref("hilal.workspaces.pinned.public", false);
+        Services.prefs.setBoolPref("hilal.workspaces.groups.public", false);
+        if (hilalWsCheckbox) {
+          hilalWsCheckbox.checked = true;
+        }
+        if (hilalWsPinnedPublicCheckbox) {
+          hilalWsPinnedPublicCheckbox.checked = false;
+        }
+        if (hilalWsGroupsPublicCheckbox) {
+          hilalWsGroupsPublicCheckbox.checked = false;
+        }
+      }
+    });
+  },
+};
+
 var {
   InternalHandlerInfoWrapper,
   getFileDisplayName,
