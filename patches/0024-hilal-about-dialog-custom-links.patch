diff --git a/browser/base/content/utilityOverlay.js b/browser/base/content/utilityOverlay.js
index e692f340a0fb..b10db2462195 100644
--- a/browser/base/content/utilityOverlay.js
+++ b/browser/base/content/utilityOverlay.js
@@ -534,5 +534,8 @@ function makeURLAbsolute(aBase, aUrl) {
 
 function getHelpLinkURL(aHelpTopic) {
   var url = Services.urlFormatter.formatURLPref("app.support.baseURL");
+  if (url.includes("github.com") || url.includes("hilal.gkdevstudio.org")) {
+    return url;
+  }
   return url + aHelpTopic;
 }
