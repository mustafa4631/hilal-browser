+      if (buildID) {
+        baseVersion += `, build ${buildID}`;
+      }
+      version += ` (${baseVersion})`;
+    }
+
     // Append "(32-bit)" or "(64-bit)" build architecture to the version number:
     let bundle = Services.strings.createBundle(
       "chrome://browser/locale/browser.properties"
