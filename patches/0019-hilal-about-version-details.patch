Hilal Browser: show Firefox base version in About

The user-facing Hilal version is distinct from the underlying Firefox app
version used by the updater. Show both values, plus the build ID, so release
checks can immediately prove which Firefox base a build was produced from.

---
diff --git a/browser/base/content/aboutDialog.js b/browser/base/content/aboutDialog.js
index f6e1391baf12..d7e16c2301e2 100644
--- a/browser/base/content/aboutDialog.js
+++ b/browser/base/content/aboutDialog.js
@@ -52,7 +52,7 @@ function init() {
   ]);
   let versionIdKey = "base";
   let versionAttributes = {
-    version: AppConstants.MOZ_APP_VERSION_DISPLAY,
+    version: getHilalVersionLabel(),
   };
 
   let arch = Services.sysinfo.get("arch");
@@ -152,4 +152,19 @@ function init() {
   }
 }
 
+function getHilalVersionLabel() {
+  let displayVersion = AppConstants.MOZ_APP_VERSION_DISPLAY;
+  let appVersion = Services.appinfo.version;
+  if (!appVersion || appVersion === displayVersion) {
+    return displayVersion;
+  }
+
+  let buildID = Services.appinfo.appBuildID;
+  let baseVersion = `Firefox ${appVersion}`;
+  if (buildID) {
+    baseVersion += `, build ${buildID}`;
+  }
+  return `${displayVersion} (${baseVersion})`;
+}
+
 init();
