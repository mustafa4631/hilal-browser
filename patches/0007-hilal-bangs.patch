@@ -720,20 +721,56 @@ export var UrlbarUtils = {
    *
    * @param {SearchEngine} engine
    *   The engine to generate the query for.
    * @param {string} query
    *   The query string to search for.
    * @returns {Array}
    *   Returns an array containing the query url (string) and the
    *    post data (object).
    */
   getSearchQueryUrl(engine, query) {
+    const BANGS_MAP = lazy.HilalBangs.getBangsMap();
+
+    if (query) {
+      const trimmed = query.trim();
+      const bangRegex = /(?:^|\s)!([a-zA-Z0-9_-]+)(?:\s|$)/i;
+      const match = trimmed.match(bangRegex);
+      if (match) {
+        const bang = match[1].toLowerCase();
+        const bangWord = "!" + match[1];
+        const extractedQuery = trimmed
+          .replace(
+            new RegExp(
+              "(?:^|\\s)" +
+                bangWord.replace(/[.*+?^${}()|[\]\\\/]/g, "\\$&") +
+                "(?:\\s|$)",
+              "i"
+            ),
+            " "
+          )
+          .trim();
+
+        if (bang in BANGS_MAP) {
+          let redirectedUrl;
+          if (!extractedQuery) {
+            redirectedUrl = BANGS_MAP[bang].home;
+          } else {
+            redirectedUrl = BANGS_MAP[bang].search.replace(
+              "{query}",
+              encodeURIComponent(extractedQuery)
+            );
+          }
+          return [redirectedUrl, null];
+        }
+      }
+    }
+
     let submission = engine.getSubmission(query);
     return [submission.uri.spec, submission.postData];
   },
 
   /**
    * Ranks a URL prefix from 3 - 0 with the following preferences:
    * https:// > https://www. > http:// > http://www.
    * Higher is better for the purposes of deduping URLs.
    * Returns -1 if the prefix does not match any of the above.
    *
