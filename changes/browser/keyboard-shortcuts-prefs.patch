 };
 
+var gHilalShortcutsSettings = {
+  init() {
+    this._container = document.getElementById("hilalShortcutsContainer");
+    this._defaultsBtn = document.getElementById("hilalShortcutsRestoreDefaults");
+
+    if (!this._container) return;
+
+    this.refresh();
+
+    if (this._defaultsBtn) {
+      this._defaultsBtn.addEventListener("command", () => {
+        if (Services.prompt.confirm(window, "Restore Defaults", "Are you sure you want to restore all keyboard shortcuts to their default settings?")) {
+          Services.prefs.clearUserPref("hilal.keyboard.shortcuts.data");
+          this.refresh();
+        }
+      });
+    }
+  },
+
+  getShortcut(id) {
+    let userShortcuts = {};
+    try {
+      userShortcuts = JSON.parse(Services.prefs.getStringPref("hilal.keyboard.shortcuts.data", "{}"));
+    } catch (e) {}
+
+    if (userShortcuts[id] !== undefined) {
+      return userShortcuts[id];
+    }
+    return this.getDefaultShortcut(id);
+  },
+
+  getDefaultShortcut(id) {
+    const isMac = AppConstants.platform === "macosx";
+    const defaults = {
+      "key_toggleSidebar": isMac ? { key: "Z", modifiers: "control" } : { key: "Z", modifiers: "control,alt" },
+      "key_hilalNewWorkspace": { key: "W", modifiers: "accel,alt" },
+      "key_hilalNextWorkspace": { key: "]", modifiers: "accel,alt" },
+      "key_hilalPrevWorkspace": { key: "[", modifiers: "accel,alt" },
+      "key_hilalToggleWorkspaces": { key: "E", modifiers: "accel,alt" },
+      "key_hilalToggleCompactMode": { key: "M", modifiers: "accel,alt" },
+      "key_toggleCompactHideToolbar": { key: "T", modifiers: "accel,alt" },
+      "key_focusUrlbar": { key: "L", modifiers: "accel" },
+      "key_newNavigator": { key: "N", modifiers: "accel" },
+      "key_newNavigatorTab": { key: "T", modifiers: "accel" },
+      "key_closeWindow": { key: "W", modifiers: "accel,shift" },
+      "key_close": { key: "W", modifiers: "accel" },
+      "key_undoCloseTab": { key: "T", modifiers: "accel,shift" },
+      "key_gotoHistory": isMac ? { key: "H", modifiers: "accel,shift" } : { key: "H", modifiers: "accel" },
+      "key_viewBookmarksSidebar": { key: "B", modifiers: "accel" }
+    };
+    return defaults[id] || { key: "", modifiers: "" };
+  },
+
+  refresh() {
+    this._container.textContent = "";
+
+    const categories = [
+      {
+        id: "workspaces",
+        title: "Workspaces",
+        items: [
+          { id: "key_hilalNewWorkspace", name: "New Workspace", desc: "Create a new workspace to organize your tabs" },
+          { id: "key_hilalToggleWorkspaces", name: "Toggle Workspaces Panel", desc: "Show or hide the workspace list sidebar" },
+          { id: "key_hilalNextWorkspace", name: "Next Workspace", desc: "Switch to the next active workspace" },
+          { id: "key_hilalPrevWorkspace", name: "Previous Workspace", desc: "Switch to the previous active workspace" }
+        ]
+      },
+      {
+        id: "sidebar",
+        title: "Sidebar & Compact Mode",
+        items: [
+          { id: "key_toggleSidebar", name: "Toggle Primary Sidebar", desc: "Show or hide the primary vertical sidebar" },
+          { id: "key_hilalToggleCompactMode", name: "Toggle Compact Mode", desc: "Enable or disable compact mode spacing" },
+          { id: "key_toggleCompactHideToolbar", name: "Toggle Top Toolbar", desc: "Show or hide the top toolbar in compact mode" },
+          { id: "key_viewBookmarksSidebar", name: "Bookmarks Sidebar", desc: "Toggle bookmarks sidebar panel" },
+          { id: "key_gotoHistory", name: "History Sidebar", desc: "Toggle history sidebar panel" }
+        ]
+      },
+      {
+        id: "tabs",
+        title: "Tabs & Windows",
+        items: [
+          { id: "key_newNavigatorTab", name: "New Tab", desc: "Open a new tab in the active window" },
+          { id: "key_close", name: "Close Active Tab", desc: "Close the currently selected tab" },
+          { id: "key_undoCloseTab", name: "Reopen Closed Tab", desc: "Restore the last tab you closed" },
+          { id: "key_newNavigator", name: "New Window", desc: "Open a new browser window" },
+          { id: "key_closeWindow", name: "Close Window", desc: "Close the current browser window" }
+        ]
+      },
+      {
+        id: "navigation",
+        title: "Navigation",
+        items: [
+          { id: "key_focusUrlbar", name: "Focus Address Bar", desc: "Highlight address bar for search or web address entry" }
+        ]
+      }
+    ];
+
+    for (let cat of categories) {
+      let card = this._createCategoryCard(cat);
+      this._container.appendChild(card);
+    }
+  },
+
+  _createCategoryCard(cat) {
+    let card = document.createXULElement("html:div");
+    card.setAttribute("class", "shortcuts-category-card");
+
+    let title = document.createXULElement("html:div");
+    title.setAttribute("class", "shortcuts-category-title");
+    title.textContent = cat.title;
+    card.appendChild(title);
+
+    for (let item of cat.items) {
+      let rowContainer = document.createXULElement("html:div");
+      rowContainer.setAttribute("class", "shortcut-row-container");
+      rowContainer.setAttribute("id", `container_${item.id}`);
+
+      let row = document.createXULElement("html:div");
+      row.setAttribute("class", "shortcut-row");
+
+      let info = document.createXULElement("html:div");
+      info.setAttribute("class", "shortcut-info");
+
+      let label = document.createXULElement("html:span");
+      label.setAttribute("class", "shortcut-label");
+      label.textContent = item.name;
+
+      let desc = document.createXULElement("html:span");
+      desc.setAttribute("class", "shortcut-desc");
+      desc.textContent = item.desc;
+
+      info.appendChild(label);
+      info.appendChild(desc);
+      row.appendChild(info);
+
+      let controls = document.createXULElement("html:div");
+      controls.setAttribute("class", "shortcut-controls");
+
+      let kbdContainer = document.createXULElement("html:div");
+      kbdContainer.setAttribute("class", "kbd-container");
+      
+      let shortcut = this.getShortcut(item.id);
+      this._renderKeycaps(kbdContainer, shortcut.key, shortcut.modifiers);
+      controls.appendChild(kbdContainer);
+
+      let btnEdit = document.createXULElement("html:button");
+      btnEdit.setAttribute("class", "shortcut-action-btn");
+      btnEdit.textContent = "Edit";
+      btnEdit.addEventListener("click", () => {
+        this._startCapture(item.id, btnEdit, kbdContainer, rowContainer);
+      });
+      controls.appendChild(btnEdit);
+
+      let btnClear = document.createXULElement("html:button");
+      btnClear.setAttribute("class", "shortcut-clear-btn");
+      btnClear.textContent = "×";
+      btnClear.setAttribute("title", "Clear shortcut");
+      btnClear.addEventListener("click", () => {
+        this._save(item.id, "", "");
+      });
+      controls.appendChild(btnClear);
+
+      row.appendChild(controls);
+      rowContainer.appendChild(row);
+      card.appendChild(rowContainer);
+    }
+
+    return card;
+  },
+
+  _renderKeycaps(container, key, modifiers) {
+    container.textContent = "";
+    if (!key && !modifiers) {
+      let span = document.createXULElement("html:span");
+      span.style.opacity = "0.5";
+      span.textContent = "Disabled";
+      container.appendChild(span);
+      return;
+    }
+
+    let parts = [];
+    if (modifiers) {
+      if (modifiers.includes("accel") || modifiers.includes("control")) {
+        parts.push(AppConstants.platform === "macosx" ? "Cmd" : "Ctrl");
+      }
+      if (modifiers.includes("alt")) {
+        parts.push(AppConstants.platform === "macosx" ? "Option" : "Alt");
+      }
+      if (modifiers.includes("shift")) {
+        parts.push("Shift");
+      }
+    }
+    if (key) {
+      parts.push(key);
+    }
+
+    for (let part of parts) {
+      let kbd = document.createXULElement("html:kbd");
+      kbd.setAttribute("class", "shortcut-keycap");
+      kbd.textContent = part;
+      container.appendChild(kbd);
+    }
+  },
+
+  _startCapture(id, btn, kbdContainer, rowContainer) {
+    btn.setAttribute("class", "shortcut-action-btn recording-active");
+    btn.textContent = "Recording...";
+    btn.focus();
+
+    // Clear conflict banners if any
+    let activeBanner = rowContainer.querySelector(".shortcut-conflict-banner");
+    if (activeBanner) activeBanner.remove();
+
+    const updateLivePreview = (e) => {
+      let mods = [];
+      if (e.metaKey) mods.push("accel");
+      if (e.ctrlKey) mods.push("control");
+      if (e.altKey) mods.push("alt");
+      if (e.shiftKey) mods.push("shift");
+
+      let k = e.key;
+      if (["Meta", "Control", "Alt", "Shift"].includes(k)) {
+        k = "";
+      } else if (k.length === 1) {
+        k = k.toUpperCase();
+      }
+
+      this._renderKeycaps(kbdContainer, k, mods.join(","));
+    };
+
+    const handler = (e) => {
+      e.preventDefault();
+      e.stopPropagation();
+
+      if (e.key === "Escape") {
+        cleanup();
+        this.refresh();
+        return;
+      }
+
+      let modifiers = [];
+      if (e.metaKey) modifiers.push("accel");
+      if (e.ctrlKey) modifiers.push("control");
+      if (e.altKey) modifiers.push("alt");
+      if (e.shiftKey) modifiers.push("shift");
+
+      let key = e.key;
+      // Filter out isolated modifier key presses
+      if (["Meta", "Control", "Alt", "Shift"].includes(key)) {
+        updateLivePreview(e);
+        return;
+      }
+
+      if (key.length === 1) {
+        key = key.toUpperCase();
+      }
+
+      cleanup();
+      this._handleCapturedShortcut(id, key, modifiers.join(","), rowContainer);
+    };
+
+    const keyupHandler = (e) => {
+      updateLivePreview(e);
+    };
+
+    const blurHandler = () => {
+      cleanup();
+      this.refresh();
+    };
+
+    const cleanup = () => {
+      btn.removeEventListener("keydown", handler, true);
+      btn.removeEventListener("keyup", keyupHandler, true);
+      btn.removeEventListener("blur", blurHandler, true);
+      btn.setAttribute("class", "shortcut-action-btn");
+      btn.textContent = "Edit";
+    };
+
+    btn.addEventListener("keydown", handler, true);
+    btn.addEventListener("keyup", keyupHandler, true);
+    btn.addEventListener("blur", blurHandler, true);
+  },
+
+  _handleCapturedShortcut(id, key, modifiers, rowContainer) {
+    let conflict = this._detectConflict(id, key, modifiers);
+    if (conflict) {
+      this._showConflictBanner(id, key, modifiers, conflict, rowContainer);
+    } else {
+      this._save(id, key, modifiers);
+    }
+  },
+
+  _detectConflict(id, key, modifiers) {
+    if (!key && !modifiers) return null;
+
+    const categories = [
+      {
+        items: [
+          { id: "key_hilalNewWorkspace", name: "New Workspace" },
+          { id: "key_hilalToggleWorkspaces", name: "Toggle Workspaces Panel" },
+          { id: "key_hilalNextWorkspace", name: "Next Workspace" },
+          { id: "key_hilalPrevWorkspace", name: "Previous Workspace" },
+          { id: "key_toggleSidebar", name: "Toggle Primary Sidebar" },
+          { id: "key_hilalToggleCompactMode", name: "Toggle Compact Mode" },
+          { id: "key_toggleCompactHideToolbar", name: "Toggle Top Toolbar" },
+          { id: "key_viewBookmarksSidebar", name: "Bookmarks Sidebar" },
+          { id: "key_gotoHistory", name: "History Sidebar" },
+          { id: "key_newNavigatorTab", name: "New Tab" },
+          { id: "key_close", name: "Close Active Tab" },
+          { id: "key_undoCloseTab", name: "Reopen Closed Tab" },
+          { id: "key_newNavigator", name: "New Window" },
+          { id: "key_closeWindow", name: "Close Window" },
+          { id: "key_focusUrlbar", name: "Focus Address Bar" }
+        ]
+      }
+    ];
+
+    for (let cat of categories) {
+      for (let item of cat.items) {
+        if (item.id === id) continue;
+        let other = this.getShortcut(item.id);
+        if (other.key === key && other.modifiers === modifiers) {
+          return item;
+        }
+      }
+    }
+    return null;
+  },
+
+  _showConflictBanner(id, key, modifiers, conflict, rowContainer) {
+    let activeBanner = rowContainer.querySelector(".shortcut-conflict-banner");
+    if (activeBanner) activeBanner.remove();
+
+    let banner = document.createXULElement("html:div");
+    banner.setAttribute("class", "shortcut-conflict-banner");
+
+    let text = document.createXULElement("html:span");
+    text.setAttribute("class", "shortcut-conflict-text");
+    text.textContent = `Conflicts with "${conflict.name}"`;
+    banner.appendChild(text);
+
+    let actions = document.createXULElement("html:div");
+    actions.setAttribute("class", "shortcut-conflict-actions");
+
+    let btnOverwrite = document.createXULElement("html:button");
+    btnOverwrite.setAttribute("class", "conflict-action-link");
+    btnOverwrite.textContent = "Overwrite";
+    btnOverwrite.addEventListener("click", () => {
+      this._overwrite(id, key, modifiers, conflict.id);
+    });
+    actions.appendChild(btnOverwrite);
+
+    let btnCancel = document.createXULElement("html:button");
+    btnCancel.setAttribute("class", "conflict-action-link");
+    btnCancel.textContent = "Cancel";
+    btnCancel.addEventListener("click", () => {
+      this.refresh();
+    });
+    actions.appendChild(btnCancel);
+
+    banner.appendChild(actions);
+    rowContainer.appendChild(banner);
+  },
+
+  _overwrite(id, key, modifiers, conflictId) {
+    let userShortcuts = {};
+    try {
+      userShortcuts = JSON.parse(Services.prefs.getStringPref("hilal.keyboard.shortcuts.data", "{}"));
+    } catch (e) {}
+
+    userShortcuts[conflictId] = { key: "", modifiers: "" };
+    userShortcuts[id] = { key, modifiers };
+
+    Services.prefs.setStringPref("hilal.keyboard.shortcuts.data", JSON.stringify(userShortcuts));
+    this.refresh();
+  },
+
+  _save(id, key, modifiers) {
+    let userShortcuts = {};
+    try {
+      userShortcuts = JSON.parse(Services.prefs.getStringPref("hilal.keyboard.shortcuts.data", "{}"));
+    } catch (e) {}
+
+    userShortcuts[id] = { key, modifiers };
+    Services.prefs.setStringPref("hilal.keyboard.shortcuts.data", JSON.stringify(userShortcuts));
+    this.refresh();
+  }
+};
