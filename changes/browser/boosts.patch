+nsHilalBoostsBackend::nsHilalBoostsBackend() = default;
+
+void nsHilalBoostsBackend::Init() {
+  nsCOMPtr<nsIObserverService> obs = mozilla::services::GetObserverService();
+  if (obs) {
+    obs->AddObserver(this, "hilal-boost-updated", false);
+    obs->AddObserver(this, "xpcom-shutdown", false);
+  }
+}
+
+auto nsHilalBoostsBackend::GetInstance() -> nsHilalBoostsBackend* {
+  if (!XRE_IsContentProcess()) {
+    return nullptr;
+  }
+  if (!sHilalBoostsBackend) {
+    sHilalBoostsBackend = new nsHilalBoostsBackend();
+    sHilalBoostsBackend->Init();
+    mozilla::ClearOnShutdown(&sHilalBoostsBackend);
+  }
+  return sHilalBoostsBackend.get();
+}
+
+NS_IMETHODIMP
+nsHilalBoostsBackend::Observe(nsISupports* aSubject, const char* aTopic,
+                              const char16_t* aData) {
+  if (strcmp(aTopic, "xpcom-shutdown") == 0) {
+    nsCOMPtr<nsIObserverService> obs = mozilla::services::GetObserverService();
+    if (obs) {
+      obs->RemoveObserver(this, "hilal-boost-updated");
+      obs->RemoveObserver(this, "xpcom-shutdown");
+    }
+    return NS_OK;
+  }
+  if (strcmp(aTopic, "hilal-boost-updated") == 0) {
+    nsAutoString dataStr16(aData);
+    NS_ConvertUTF16toUTF8 dataStr(dataStr16);
+    int32_t firstPipe = dataStr.FindChar('|');
+    fprintf(stderr, "HILAL_OBSERVED: dataStr=%s, firstPipe=%d\n", dataStr.get(), firstPipe);
+    if (firstPipe != -1) {
+      nsCString domain(Substring(dataStr, 0, firstPipe));
+      nsCString rest(Substring(dataStr, firstPipe + 1));
+      fprintf(stderr, "HILAL_OBSERVED_PARSED: domain=%s, rest=%s\n", domain.get(), rest.get());
+      unsigned int tempAccent = 0;
+      float tempRotation = 0.0f;
+      int tempInverted = 0;
+      int scanCount = sscanf(rest.get(), "%u|%f|%d", &tempAccent, &tempRotation, &tempInverted);
+      fprintf(stderr, "HILAL_OBSERVED_SSCANF: scanCount=%d, accent=%u, rot=%f, inv=%d\n", scanCount, tempAccent, tempRotation, tempInverted);
+      if (scanCount == 3) {
+        if (tempAccent == 0 && tempInverted == 0) {
+          mBoostsMap.Remove(domain);
+        } else {
+          mBoostsMap.InsertOrUpdate(domain, HilalBoostData{tempAccent, tempRotation, tempInverted != 0});
+        }
+      }
+    }
+  }
+  return NS_OK;
+}
+
+void nsHilalBoostsBackend::GetBoostForDomain(const nsACString& aDomain, nscolor* aAccent,
+                                             float* aRotation, bool* aInverted) {
+  HilalBoostData data;
+  if (mBoostsMap.Get(aDomain, &data)) {
+    *aAccent = data.accent;
+    *aRotation = data.complementaryRotation;
+    *aInverted = data.inverted;
+  } else {
+    *aAccent = 0;
+    *aRotation = 0.0f;
+    *aInverted = false;
+  }
+}
