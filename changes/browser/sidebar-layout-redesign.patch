+
+var HilalCompactMode = {
+  PREF: "hilal.compact.enabled",
+  ATTR: "hilal-compact-mode",
+
+  _prefObserver: null,
+  _mouseMoveHandler: null,
+  _mouseShowTimer: null,
+  _mouseLeaveTimer: null,
+  _sidebarVisible: false,
+  _hoverZoneWidth: 32,
+  _showDelayMs: 180,
+  _leaveDelayMs: 400,
+
+  init() {
+    this._prefObserver = (_subject, _topic, _data) => {
+      this._apply(Services.prefs.getBoolPref(this.PREF, false));
+    };
+    Services.prefs.addObserver(this.PREF, this._prefObserver);
+    window.addEventListener("unload", () => this.uninit(), { once: true });
+    this._apply(Services.prefs.getBoolPref(this.PREF, false));
+  },
+
+  uninit() {
+    if (this._prefObserver) {
+      Services.prefs.removeObserver(this.PREF, this._prefObserver);
+      this._prefObserver = null;
+    }
+    this._removeMouseListeners();
+  },
+
+  get enabled() {
+    return Services.prefs.getBoolPref(this.PREF, false);
+  },
+
+  toggle() {
+    Services.prefs.setBoolPref(this.PREF, !this.enabled);
+  },
+
+  _apply(compact) {
+    document.documentElement.toggleAttribute(this.ATTR, compact);
+    this._syncToolbarButton(compact);
+    if (compact) {
+      this._addMouseListeners();
+    } else {
+      this._removeMouseListeners();
+      this._hideSidebar();
+    }
+  },
+
+  _syncToolbarButton(compact) {
+    const btn = document.getElementById("sidebar-button");
+    if (!btn) {
+      return;
+    }
+    btn.checked = compact;
+  },
+
+  _addMouseListeners() {
+    if (this._mouseMoveHandler) {
+      return;
+    }
+    this._mouseMoveHandler = event => this._onMouseMove(event);
+    window.addEventListener("mousemove", this._mouseMoveHandler);
+  },
+
+  _removeMouseListeners() {
+    if (this._mouseMoveHandler) {
+      window.removeEventListener("mousemove", this._mouseMoveHandler);
+      this._mouseMoveHandler = null;
+    }
+    if (this._mouseShowTimer) {
+      clearTimeout(this._mouseShowTimer);
+      this._mouseShowTimer = null;
+    }
+    if (this._mouseLeaveTimer) {
+      clearTimeout(this._mouseLeaveTimer);
+      this._mouseLeaveTimer = null;
+    }
+  },
+
+  _onMouseMove(event) {
+    const sidebar = document.getElementById("sidebar-main");
+    if (!sidebar) {
+      return;
+    }
+
+    this._lastMouseX = event.clientX;
+    this._lastMouseY = event.clientY;
+
+    const isLeft = SidebarController._positionStart;
+    const windowWidth = window.innerWidth;
+    const isNearEdge = isLeft
+      ? (this._lastMouseX <= this._hoverZoneWidth)
+      : (this._lastMouseX >= windowWidth - this._hoverZoneWidth);
+
+    if (isNearEdge && !this._sidebarVisible) {
+      if (this._mouseShowTimer) {
+        return;
+      }
+      this._mouseShowTimer = setTimeout(() => {
+        this._mouseShowTimer = null;
+        const s = document.getElementById("sidebar-main");
+        if (s) {
+          const isStillLeft = SidebarController._positionStart;
+          const isStillNear = isStillLeft
+            ? (this._lastMouseX <= this._hoverZoneWidth)
+            : (this._lastMouseX >= window.innerWidth - this._hoverZoneWidth);
+          if (isStillNear) {
+            this._showSidebar(s);
+          }
+        }
+      }, this._showDelayMs);
+    } else if (this._sidebarVisible) {
+      const sidebarRect = sidebar.getBoundingClientRect();
+      const width = 280;
+      const isInsideSidebar = isLeft
+        ? (this._lastMouseX >= 0 && this._lastMouseX <= width &&
+           this._lastMouseY >= sidebarRect.top && this._lastMouseY <= sidebarRect.bottom)
+        : (this._lastMouseX >= windowWidth - width && this._lastMouseX <= windowWidth &&
+           this._lastMouseY >= sidebarRect.top && this._lastMouseY <= sidebarRect.bottom);
+
+      if (!isInsideSidebar && !isNearEdge) {
+        this._scheduleHide();
+      } else {
+        this._cancelHide();
+      }
+    } else if (!isNearEdge && this._mouseShowTimer) {
+      clearTimeout(this._mouseShowTimer);
+      this._mouseShowTimer = null;
+    }
+  },
+
+  _showSidebar(sidebar) {
+    this._cancelHide();
+    if (this._mouseShowTimer) {
+      clearTimeout(this._mouseShowTimer);
+      this._mouseShowTimer = null;
+    }
+    this._sidebarVisible = true;
+    sidebar.classList.add("hilal-compact-visible");
+  },
+
+  _hideSidebar() {
+    this._sidebarVisible = false;
+    const sidebar = document.getElementById("sidebar-main");
+    if (sidebar) {
+      sidebar.classList.remove("hilal-compact-visible");
+    }
+  },
+
+  _scheduleHide() {
+    if (this._mouseLeaveTimer) {
+      return;
+    }
+    this._mouseLeaveTimer = setTimeout(() => {
+      this._mouseLeaveTimer = null;
+      this._hideSidebar();
+    }, this._leaveDelayMs);
+  },
+
+  _cancelHide() {
+    if (this._mouseLeaveTimer) {
+      clearTimeout(this._mouseLeaveTimer);
+      this._mouseLeaveTimer = null;
+    }
+  },
+};
