diff --git a/browser/components/preferences/main.js b/browser/components/preferences/main.js
--- a/browser/components/preferences/main.js
+++ b/browser/components/preferences/main.js
@@ -2207,6 +2207,117 @@ var gHilalPane = {
     }
 
     refreshBangsList();
+
+    // -- Hilal Language Customization -----------------------------------------
+    const languageSelect = document.getElementById("hilalLanguageSelect");
+    const languageApplyBtn = document.getElementById("hilalLanguageApply");
+
+    if (languageSelect && languageApplyBtn) {
+      const initLanguageUI = async () => {
+        let available = [];
+        try {
+          const { LangPackMatcher } = ChromeUtils.importESModule(
+            "resource://gre/modules/LangPackMatcher.sys.mjs"
+          );
+          available = await LangPackMatcher.getAvailableLocales();
+        } catch (e) {
+          console.error("Failed to dynamically load locales:", e);
+        }
+
+        if (!available || !available.length) {
+          available = ["en-US", "tr"];
+        }
+
+        if (!available.includes("en-US")) {
+          available.push("en-US");
+        }
+        if (!available.includes("tr")) {
+          available.push("tr");
+        }
+
+        let localeNames = [];
+        try {
+          localeNames = Services.intl.getLocaleDisplayNames(undefined, available, {
+            preferNative: true,
+          });
+        } catch (e) {
+          console.error("Failed to get locale display names:", e);
+          localeNames = available.map(code =>
+            code.startsWith("tr") ? "Türkçe" : (code.startsWith("en") ? "English (US)" : code)
+          );
+        }
+
+        languageSelect.textContent = "";
+
+        const currentLocale = Services.locale.appLocaleAsBCP47;
+        const systemLabel = currentLocale.startsWith("tr")
+          ? "Sistem Dili (Varsayılan)"
+          : "System Language (Default)";
+
+        const systemOption = document.createElement("option");
+        systemOption.value = "";
+        systemOption.textContent = systemLabel;
+        languageSelect.appendChild(systemOption);
+
+        for (let i = 0; i < available.length; i++) {
+          const code = available[i];
+          const name = localeNames[i] || code;
+          const option = document.createElement("option");
+          option.value = code;
+          option.textContent = name;
+          languageSelect.appendChild(option);
+        }
+
+        let currentPref = "";
+        try {
+          currentPref = Services.prefs.getCharPref("intl.locale.requested");
+        } catch (e) {
+          // Empty or doesn't exist
+        }
+        languageSelect.value = currentPref;
+      };
+
+      initLanguageUI();
+
+      languageApplyBtn.addEventListener("command", () => {
+        const selected = languageSelect.value;
+        let currentPref = "";
+        try {
+          currentPref = Services.prefs.getCharPref("intl.locale.requested");
+        } catch (e) {
+          // Empty
+        }
+
+        if (selected === currentPref) {
+          // No change, no restart needed
+          return;
+        }
+
+        Services.prefs.setCharPref("intl.locale.requested", selected);
+
+        const currentLocale = Services.locale.appLocaleAsBCP47;
+        const title = currentLocale.startsWith("tr") ? "Yeniden Başlatma Gerekli" : "Restart Required";
+        const message = currentLocale.startsWith("tr")
+          ? "Dil değişikliğini uygulamak için tarayıcının yeniden başlatılması gerekiyor. Şimdi yeniden başlatılsın mı?"
+          : "The browser needs to be restarted to apply language changes. Restart now?";
+
+        if (Services.prompt.confirm(window, title, message)) {
+          let cancelQuit = Cc["@mozilla.org/supports-PRBool;1"].createInstance(
+            Ci.nsISupportsPRBool
+          );
+          Services.obs.notifyObservers(
+            cancelQuit,
+            "quit-application-requested",
+            "restart"
+          );
+          if (!cancelQuit.data) {
+            Services.startup.quit(
+              Services.startup.eAttemptQuit | Services.startup.eRestart
+            );
+          }
+        }
+      });
+    }
   },
 };
 
